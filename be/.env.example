# Copy this file to .env and fill in real values before starting the backend.
# .env is gitignored — never commit real credentials.

# Postgres connection string.
# Local dev: matches the docker-compose.yml service on port 5433.
# Prod: use a managed Postgres URL (e.g. Cloud SQL, RDS, Supabase).
DATABASE_URL=postgresql://match3:match3dev@localhost:5433/match3

# Optional: override the default connection pool size (default: 10).
# DB_POOL_SIZE=10

# Optional: Socket.IO server port (default: 3001).
# PORT=3001

# Optional: simulate network RTT for the latency harness (ms).
# SIM_RTT_MS=0
