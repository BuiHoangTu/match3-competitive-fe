# Backend database URL (Docker uses internal postgres hostname)
# For local development: postgresql://match3:match3dev@localhost:5433/match3
# For Docker Compose: postgresql://match3:match3dev@postgres:5432/match3
DATABASE_URL=postgresql://match3:match3dev@postgres:5432/match3

# Frontend backend server URL (used by VITE build)
# For Docker: http://backend:3001 (internal) or http://localhost:3001 (if backend on host)
VITE_BACKEND_URL=http://localhost:3001

# Firebase / Authentication (optional, needed for production sign-in)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
